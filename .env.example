# 复制为 .env 并填入你的 Key
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# DeepSeek（推荐：便宜 + 中文效果好）
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_LLM_MODEL=deepseek-chat
# DEEPSEEK_EMBED_MODEL=BAAI/bge-small-zh-v1.5   # 本地 HuggingFace，首次自动下载

# Anthropic（可选，需同时配置 OPENAI_API_KEY 用于 embedding）
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_LLM_MODEL=claude-haiku-4-5-20251001

# Ollama（完全本地，无需 API Key）
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text

# 检索参数
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# 调试模式（打印 top chunks）
DEBUG=false
